# ========== 必填项（无默认值，启动时必须设置） ==========
SECRET_KEY=your-secret-key-change-me
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your-minio-secret

# ========== 可选项（有默认值） ==========
# DEBUG=false
# APP_NAME=博物馆视频智能监控分析平台
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS（逗号分隔）
# CORS_ORIGINS=http://localhost:3000,http://localhost:80,http://localhost

# MySQL
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=museum_monitor

# Milvus
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_COLLECTION=museum_events

# vLLM / 云端大模型 API（兼容 OpenAI 协议）
# 本地 vLLM：
# VLLM_TEXT_URL=http://localhost:8000/v1
# VLLM_VISION_URL=http://localhost:8001/v1
# VLLM_TEXT_MODEL=Qwen3-32B
# VLLM_VISION_MODEL=Qwen3.5-35B-A3B
# VLLM_API_KEY=not-needed
#
# 通义千问：
# VLLM_TEXT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VLLM_VISION_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VLLM_TEXT_MODEL=qwen-max
# VLLM_VISION_MODEL=qwen-vl-max
# VLLM_API_KEY=sk-your-dashscope-key
#
# DeepSeek：
# VLLM_TEXT_URL=https://api.deepseek.com/v1
# VLLM_TEXT_MODEL=deepseek-chat
# VLLM_API_KEY=sk-your-deepseek-key
#
# OpenAI：
# VLLM_TEXT_URL=https://api.openai.com/v1
# VLLM_VISION_URL=https://api.openai.com/v1
# VLLM_TEXT_MODEL=gpt-4o
# VLLM_VISION_MODEL=gpt-4o
# VLLM_API_KEY=sk-your-openai-key

# Embedding（为空时复用 VLLM_TEXT_URL 和 VLLM_API_KEY）
# EMBEDDING_URL=
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=bge-large-zh-v1.5
# RERANKER_MODEL=bge-reranker-v2-m3

# MinIO
# MINIO_ENDPOINT=localhost:9000
# MINIO_BUCKET=museum-videos

# Storage
# LOCAL_VIDEO_PATH=./data/videos
# LOCAL_FRAME_PATH=./data/frames

# YOLO
# YOLO_MODEL_PATH=./models/yolo11m.pt
# YOLO_POSE_MODEL_PATH=./models/yolo11m-pose.pt
# YOLO_CONFIDENCE=0.5
# YOLO_INPUT_SIZE=640

# Alert Webhook（报警推送）
# ALERT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# ALERT_WEBHOOK_TYPE=feishu  # feishu / dingtalk

# RTSP
# RTSP_SEGMENT_DURATION=300

# Video Analysis
# SKIP_FRAME_INTERVAL=25
# PERSON_EXPAND_SECONDS=5.0
# MERGE_GAP_SECONDS=3.0
# SEGMENT_DURATION=60
# FRAME_INTERVAL=1
